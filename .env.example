# .env.example
#
# Template for environment variables used by this project.
# Copy this file to .env and replace placeholders with real values.
# .env is gitignored — never commit real secrets.

# Where the FastAPI service loads the model artifact from.
MODEL_PATH=models/artifact.pkl

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# API key required to call /predict endpoints. Leave unset to disable auth.
API_KEY=replace_with_real_key
